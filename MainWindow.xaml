<Window x:Class="ScreenFind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenFind"
        Width="560" Height="420"
        MinWidth="400" MinHeight="340"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ScreenFind" 
                       FontSize="30" FontWeight="Bold" Foreground="#CDD6F4"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ctrl+F for your entire screen" 
                       FontSize="14" Foreground="#A6ADC8"
                       HorizontalAlignment="Center" Margin="0,4,0,20"/>
            
            <StackPanel HorizontalAlignment="Center">
                <Border x:Name="HotkeyBorder" Background="#313244" CornerRadius="8"
                        Padding="16,10" HorizontalAlignment="Center"
                        Cursor="Hand" MouseLeftButtonDown="HotkeyBorder_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3B3B50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Hotkey:  " FontSize="15" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HotkeyText" FontSize="14" Foreground="#F5E0DC"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="HotkeyHint" Text="click to change"
                           FontSize="10" Foreground="#585B70"
                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
            </StackPanel>
            
            <Button x:Name="TrayButton" Content="Minimize to Tray"
                    FontSize="13" FontFamily="Segoe UI"
                    Foreground="#CDD6F4" Background="#45475A"
                    BorderThickness="0" Padding="16,8"
                    Cursor="Hand"
                    HorizontalAlignment="Center" Margin="0,16,0,0"
                    Click="TrayButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock Text="Runs in the background from system tray"
                       FontSize="11" Foreground="#585B70"
                       HorizontalAlignment="Center" Margin="0,10,0,0"/>

            <CheckBox x:Name="DragToSelectCheckbox"
                      Content="Drag to select text on overlay"
                      FontSize="12" Foreground="#A6ADC8"
                      HorizontalAlignment="Center" Margin="0,14,0,0"
                      Checked="DragToSelectCheckbox_Changed"
                      Unchecked="DragToSelectCheckbox_Changed">
                <CheckBox.Style>
                    <Style TargetType="CheckBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="box" Width="18" Height="18"
                                                Background="#45475A" CornerRadius="4"
                                                BorderBrush="#585B70" BorderThickness="1"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock x:Name="check" Text="&#x2713;"
                                                       Foreground="#A6E3A1" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="Collapsed"/>
                                        </Border>
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="box" Property="BorderBrush" Value="#A6E3A1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="box" Property="Background" Value="#585B70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </CheckBox.Style>
            </CheckBox>

            <CheckBox x:Name="EnhanceOcrCheckbox"
                      Content="Enhance OCR (helps with desktop icons &amp; low-contrast text)"
                      FontSize="12" Foreground="#A6ADC8"
                      HorizontalAlignment="Center" Margin="0,14,0,0"
                      Checked="EnhanceOcrCheckbox_Changed"
                      Unchecked="EnhanceOcrCheckbox_Changed">
                <CheckBox.Style>
                    <Style TargetType="CheckBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="box" Width="18" Height="18"
                                                Background="#45475A" CornerRadius="4"
                                                BorderBrush="#585B70" BorderThickness="1"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock x:Name="check" Text="&#x2713;"
                                                       Foreground="#A6E3A1" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="Collapsed"/>
                                        </Border>
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="box" Property="BorderBrush" Value="#A6E3A1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="box" Property="Background" Value="#585B70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </CheckBox.Style>
            </CheckBox>
        </StackPanel>
    </Grid>
</Window>

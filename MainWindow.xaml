<Window x:Class="ScreenFind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenFind"
        Width="560" Height="480"
        MinWidth="400" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <!-- Thin dark scrollbar thumb -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#45475A" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical scrollbar: thin track, no arrows -->
        <ControlTemplate x:Key="VerticalScrollBar" TargetType="ScrollBar">
            <Grid Width="8">
                <Border Background="Transparent" CornerRadius="4"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Apply to all ScrollBars in this window -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Catppuccin checkbox style (reusable) -->
        <Style x:Key="CatppuccinCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="box" Width="18" Height="18"
                                    Background="#45475A" CornerRadius="4"
                                    BorderBrush="#585B70" BorderThickness="1"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock x:Name="check" Text="&#x2713;"
                                           Foreground="#A6E3A1" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#A6E3A1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section card style -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Section header text style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#585B70"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Tab bar -->
            <RowDefinition Height="*"/>     <!-- Tab content -->
        </Grid.RowDefinitions>

        <!-- ═══ Header (always visible) ═══ -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="ScreenFind"
                       FontSize="30" FontWeight="Bold" Foreground="#CDD6F4"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ctrl+F for your entire screen"
                       FontSize="14" Foreground="#A6ADC8"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══ Tab bar ═══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <!-- Settings tab -->
            <Border x:Name="SettingsTabBorder" Cursor="Hand"
                    Padding="12,6" Margin="0,0,10,0"
                    BorderThickness="0,0,0,2" BorderBrush="#CBA6F7"
                    Background="Transparent"
                    MouseLeftButtonDown="SettingsTab_Click">
                <TextBlock x:Name="SettingsTabText" Text="Settings"
                           FontSize="14" Foreground="#CDD6F4" FontWeight="SemiBold"/>
            </Border>
            <!-- About tab -->
            <Border x:Name="AboutTabBorder" Cursor="Hand"
                    Padding="12,6" Margin="10,0,0,0"
                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                    Background="Transparent"
                    MouseLeftButtonDown="AboutTab_Click">
                <TextBlock x:Name="AboutTabText" Text="About"
                           FontSize="14" Foreground="#585B70" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- ═══ Settings panel ═══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="SettingsPanel" Width="360" Margin="0,0,0,10">

                <!-- ── Hotkey card ── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="HOTKEY" Style="{StaticResource SectionHeader}"/>
                        <Border x:Name="HotkeyBorder" CornerRadius="8"
                                Padding="14,10" Cursor="Hand"
                                MouseLeftButtonDown="HotkeyBorder_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#45475A"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#585B70"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <TextBlock x:Name="HotkeyText" FontSize="14" Foreground="#F5E0DC"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HotkeyHint" Text="click to change"
                                           FontSize="10" Foreground="#6C7086"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── General card ── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="GENERAL" Style="{StaticResource SectionHeader}"/>
                        <CheckBox x:Name="StartWithWindowsCheckbox"
                                  Content="Start with Windows"
                                  Style="{StaticResource CatppuccinCheckBox}" Margin="0"
                                  Checked="StartWithWindowsCheckbox_Changed"
                                  Unchecked="StartWithWindowsCheckbox_Changed"/>
                        <TextBlock Text="Launches minimized to system tray on login"
                                   FontSize="11" Foreground="#585B70" Margin="26,2,0,0"/>

                        <Button x:Name="TrayButton" Content="Minimize to Tray"
                                FontSize="12" FontFamily="Segoe UI"
                                Foreground="#CDD6F4" Background="#45475A"
                                BorderThickness="0" Padding="14,7"
                                Cursor="Hand" Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Click="TrayButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#585B70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ── Overlay card ── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="OVERLAY" Style="{StaticResource SectionHeader}"/>
                        <CheckBox x:Name="DragToSelectCheckbox"
                                  Content="Drag to select text"
                                  Style="{StaticResource CatppuccinCheckBox}" Margin="0"
                                  Checked="DragToSelectCheckbox_Changed"
                                  Unchecked="DragToSelectCheckbox_Changed"/>
                        <CheckBox x:Name="EnhanceOcrCheckbox"
                                  Content="Enhanced OCR (slower, better for low-contrast text)"
                                  Style="{StaticResource CatppuccinCheckBox}"
                                  Checked="EnhanceOcrCheckbox_Changed"
                                  Unchecked="EnhanceOcrCheckbox_Changed"/>
                    </StackPanel>
                </Border>

                <!-- ── Monitors card ── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="MONITORS" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="MonitorListPanel"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ About panel (hidden by default) ═══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      x:Name="AboutPanel" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" Margin="0,4,0,10">
                <!-- Description -->
                <TextBlock Text="Search any text visible on your screen using OCR."
                           FontSize="13" Foreground="#A6ADC8"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- Keyboard Shortcuts heading -->
                <TextBlock Text="Keyboard Shortcuts"
                           FontSize="15" Foreground="#CDD6F4" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>

                <!-- Shortcut rows -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Hotkey -->
                    <TextBlock x:Name="AboutHotkeyLabel" Text="Ctrl + Shift + F"
                               Grid.Row="0" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Open search overlay"
                               Grid.Row="0" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 1: Enter / Shift+Enter -->
                    <TextBlock Text="Enter / Shift+Enter"
                               Grid.Row="1" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Next / Previous match"
                               Grid.Row="1" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 2: Escape -->
                    <TextBlock Text="Escape"
                               Grid.Row="2" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Close overlay"
                               Grid.Row="2" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 3: Click highlight -->
                    <TextBlock Text="Click highlight"
                               Grid.Row="3" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Copy matched text"
                               Grid.Row="3" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 4: Drag on overlay -->
                    <TextBlock Text="Drag on overlay"
                               Grid.Row="4" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Select text region"
                               Grid.Row="4" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>
                </Grid>

                <!-- Footer -->
                <TextBlock Text="Built with WPF + Windows OCR"
                           FontSize="11" Foreground="#45475A"
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <TextBlock x:Name="GithubLink" Text="github.com/sid1552/ScreenFind"
                           FontSize="11" Foreground="#585B70"
                           HorizontalAlignment="Center" Margin="0,6,0,0"
                           Cursor="Hand" TextDecorations="Underline"
                           MouseLeftButtonDown="GithubLink_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

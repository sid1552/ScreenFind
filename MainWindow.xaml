<Window x:Class="ScreenFind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenFind"
        Width="560" Height="480"
        MinWidth="400" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <!-- Thin dark scrollbar thumb -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#45475A" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical scrollbar: thin track, no arrows -->
        <ControlTemplate x:Key="VerticalScrollBar" TargetType="ScrollBar">
            <Grid Width="8">
                <Border Background="Transparent" CornerRadius="4"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Apply to all ScrollBars in this window -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Tab bar -->
            <RowDefinition Height="*"/>     <!-- Tab content -->
        </Grid.RowDefinitions>

        <!-- ═══ Header (always visible) ═══ -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="ScreenFind"
                       FontSize="30" FontWeight="Bold" Foreground="#CDD6F4"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ctrl+F for your entire screen"
                       FontSize="14" Foreground="#A6ADC8"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══ Tab bar ═══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <!-- Settings tab -->
            <Border x:Name="SettingsTabBorder" Cursor="Hand"
                    Padding="12,6" Margin="0,0,10,0"
                    BorderThickness="0,0,0,2" BorderBrush="#CBA6F7"
                    Background="Transparent"
                    MouseLeftButtonDown="SettingsTab_Click">
                <TextBlock x:Name="SettingsTabText" Text="Settings"
                           FontSize="14" Foreground="#CDD6F4" FontWeight="SemiBold"/>
            </Border>
            <!-- About tab -->
            <Border x:Name="AboutTabBorder" Cursor="Hand"
                    Padding="12,6" Margin="10,0,0,0"
                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                    Background="Transparent"
                    MouseLeftButtonDown="AboutTab_Click">
                <TextBlock x:Name="AboutTabText" Text="About"
                           FontSize="14" Foreground="#585B70" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- ═══ Settings panel ═══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="SettingsPanel" HorizontalAlignment="Center">
                <!-- Hotkey -->
                <Border x:Name="HotkeyBorder" CornerRadius="8"
                        Padding="16,10" HorizontalAlignment="Center"
                        Cursor="Hand" MouseLeftButtonDown="HotkeyBorder_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#313244"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3B3B50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Hotkey:  " FontSize="15" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HotkeyText" FontSize="14" Foreground="#F5E0DC"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="HotkeyHint" Text="click to change"
                           FontSize="10" Foreground="#585B70"
                           HorizontalAlignment="Center" Margin="0,3,0,0"/>

                <!-- Minimize to Tray -->
                <Button x:Name="TrayButton" Content="Minimize to Tray"
                        FontSize="13" FontFamily="Segoe UI"
                        Foreground="#CDD6F4" Background="#45475A"
                        BorderThickness="0" Padding="16,8"
                        Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,16,0,0"
                        Click="TrayButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#585B70"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Text="Runs in the background from system tray"
                           FontSize="11" Foreground="#585B70"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>

                <!-- Drag to select checkbox -->
                <CheckBox x:Name="DragToSelectCheckbox"
                          Content="Drag to select text on overlay"
                          FontSize="12" Foreground="#A6ADC8"
                          HorizontalAlignment="Center" Margin="0,14,0,0"
                          Checked="DragToSelectCheckbox_Changed"
                          Unchecked="DragToSelectCheckbox_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border x:Name="box" Width="18" Height="18"
                                                    Background="#45475A" CornerRadius="4"
                                                    BorderBrush="#585B70" BorderThickness="1"
                                                    VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock x:Name="check" Text="&#x2713;"
                                                           Foreground="#A6E3A1" FontSize="13" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="box" Property="BorderBrush" Value="#A6E3A1"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="box" Property="Background" Value="#585B70"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- Enhance OCR checkbox -->
                <CheckBox x:Name="EnhanceOcrCheckbox"
                          Content="Enhance OCR (helps with desktop icons &amp; low-contrast text)"
                          FontSize="12" Foreground="#A6ADC8"
                          HorizontalAlignment="Center" Margin="0,14,0,0"
                          Checked="EnhanceOcrCheckbox_Changed"
                          Unchecked="EnhanceOcrCheckbox_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border x:Name="box" Width="18" Height="18"
                                                    Background="#45475A" CornerRadius="4"
                                                    BorderBrush="#585B70" BorderThickness="1"
                                                    VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock x:Name="check" Text="&#x2713;"
                                                           Foreground="#A6E3A1" FontSize="13" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="box" Property="BorderBrush" Value="#A6E3A1"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="box" Property="Background" Value="#585B70"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- Monitors section -->
                <TextBlock Text="Monitors"
                           FontSize="13" Foreground="#A6ADC8" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,18,0,6"/>
                <StackPanel x:Name="MonitorListPanel"
                            HorizontalAlignment="Center" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ About panel (hidden by default) ═══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      x:Name="AboutPanel" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" Margin="0,4,0,10">
                <!-- Description -->
                <TextBlock Text="Search any text visible on your screen using OCR."
                           FontSize="13" Foreground="#A6ADC8"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- Keyboard Shortcuts heading -->
                <TextBlock Text="Keyboard Shortcuts"
                           FontSize="15" Foreground="#CDD6F4" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>

                <!-- Shortcut rows -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Hotkey -->
                    <TextBlock x:Name="AboutHotkeyLabel" Text="Ctrl + Shift + F"
                               Grid.Row="0" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Open search overlay"
                               Grid.Row="0" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 1: Enter / Shift+Enter -->
                    <TextBlock Text="Enter / Shift+Enter"
                               Grid.Row="1" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Next / Previous match"
                               Grid.Row="1" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 2: Escape -->
                    <TextBlock Text="Escape"
                               Grid.Row="2" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Close overlay"
                               Grid.Row="2" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 3: Click highlight -->
                    <TextBlock Text="Click highlight"
                               Grid.Row="3" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Copy matched text"
                               Grid.Row="3" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>

                    <!-- Row 4: Drag on overlay -->
                    <TextBlock Text="Drag on overlay"
                               Grid.Row="4" Grid.Column="0"
                               FontSize="13" Foreground="#F5E0DC" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Select text region"
                               Grid.Row="4" Grid.Column="2"
                               FontSize="13" Foreground="#585B70"
                               Margin="0,0,0,10"/>
                </Grid>

                <!-- Footer -->
                <TextBlock Text="Built with WPF + Windows OCR"
                           FontSize="11" Foreground="#45475A"
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <TextBlock x:Name="GithubLink" Text="github.com/sid1552/ScreenFind"
                           FontSize="11" Foreground="#585B70"
                           HorizontalAlignment="Center" Margin="0,6,0,0"
                           Cursor="Hand" TextDecorations="Underline"
                           MouseLeftButtonDown="GithubLink_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

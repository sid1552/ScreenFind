<Window x:Class="ScreenFind.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Black"
        PreviewKeyDown="Window_PreviewKeyDown"
        Focusable="True">

    <Grid x:Name="RootGrid">
        
        <Image x:Name="ScreenshotImage" Stretch="Fill" />
        <Rectangle Fill="#88000000" />
        <Canvas x:Name="HighlightCanvas" />
        <Canvas x:Name="SelectionCanvas" Background="Transparent" IsHitTestVisible="False" />
        <Border x:Name="SearchBarBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,90,0,0"
                Background="#F2F0F0F0"
                CornerRadius="14"
                Width="620"
                Padding="16,10"
                RenderTransformOrigin="0.5,0.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.6" ShadowDepth="2" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="&#x1F50D;"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="4,0,12,0"
                           Opacity="0.6"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         FontSize="22"
                         FontFamily="Segoe UI"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="MatchInfo"
                           Grid.Column="2"
                           FontSize="13"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           Margin="8,0,6,0"/>
            </Grid>
        </Border>

        <Border x:Name="LoadingBadge"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,46,0,0"
                Background="#DD2D2D3F"
                CornerRadius="10"
                Padding="14,6">
            <TextBlock Text="&#x23F3;  Scanning screen..."
                       Foreground="#CDD6F4" FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,30"
                Background="#AA2D2D3F"
                CornerRadius="8"
                Padding="14,6">
            <TextBlock Foreground="#A6ADC8" FontSize="11" FontFamily="Segoe UI">
                <Run Text="Enter"/>
                <Run Text=" next match" Foreground="#6C7086"/>
                <Run Text="    Shift+Enter" />
                <Run Text=" prev" Foreground="#6C7086"/>
                <Run Text="    Ctrl+C" />
                <Run Text=" copy" Foreground="#6C7086"/>
                <Run Text="    Click match" />
                <Run Text=" copy" Foreground="#6C7086"/>
                <Run Text="    Drag" />
                <Run Text=" select text" Foreground="#6C7086"/>
                <Run Text="    Esc" />
                <Run Text=" close" Foreground="#6C7086"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark High Contrast — pure black bg, bright text, strong borders -->
    <SolidColorBrush x:Key="WindowBgBrush"      Color="#000000"/>
    <SolidColorBrush x:Key="CardBgBrush"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#2A2A2A"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="#3A3A3A"/>
    <SolidColorBrush x:Key="MutedBrush"          Color="#888888"/>
    <SolidColorBrush x:Key="HintBrush"           Color="#999999"/>
    <SolidColorBrush x:Key="SecondaryBrush"      Color="#CCCCCC"/>
    <SolidColorBrush x:Key="PrimaryBrush"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentTextBrush"     Color="#FFB3B3"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="#D8A8FF"/>
    <SolidColorBrush x:Key="CheckBrush"          Color="#80FF80"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#FFD700"/>
    <SolidColorBrush x:Key="ErrorBrush"          Color="#FF4444"/>
    <SolidColorBrush x:Key="FooterBrush"         Color="#555555"/>

</ResourceDictionary>
